FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir uvicorn[standard] fastapi sqlalchemy[asyncio] asyncpg alembic pydantic pydantic-settings httpx python-multipart aiofiles flwr torch torchvision

COPY backend/ /app/backend/
COPY shared/ /app/shared/
COPY flower_server/ /app/flower_server/

ENV PYTHONPATH=/app
EXPOSE 8000

CMD ["uvicorn", "backend.app.main:app", "--host", "0.0.0.0", "--port", "8000"]
